{
  "permissions": {
    "allow": [
      "PowerShell(npm *)",
      "PowerShell(Move-Item *)",
      "Bash(npm run *)",
      "Bash(git init *)",
      "Bash(git config *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git check-ignore *)",
      "PowerShell(npm install *)",
      "PowerShell(node --env-file=.env.local test-connection.mjs)",
      "PowerShell($env:NODE_OPTIONS=\"--use-system-ca\"; node --env-file=.env.local test-connection.mjs)",
      "PowerShell(Remove-Item *)",
      "PowerShell(Get-NetTCPConnection *)",
      "PowerShell(Set-Clipboard *)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing -TimeoutSec 30; \"HTTP status: \" + $r.StatusCode } catch { \"Request error: \" + $_.Exception.Message })",
      "WebFetch(domain:supabase.com)",
      "PowerShell($env:NODE_OPTIONS=\"--use-system-ca\"; node --env-file=.env.local supabase/seed-sample.mjs)",
      "PowerShell($env:NODE_OPTIONS=\"--use-system-ca\"; node --env-file=.env.local supabase/seed-tags.mjs)"
    ]
  }
}
